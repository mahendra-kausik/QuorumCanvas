# L7 production compose config — copy to `.env` (gitignored), fill in real values.
# Never commit the real `.env` (CLAUDE.md §4: the one secret this project has is AUTH_TOKEN).

# Shared bearer token gating gateway WS + HTTP (L6). Generate with: openssl rand -hex 32
AUTH_TOKEN=

# Comma-separated CORS allowlist for the gateway. Set to the deployed Vercel frontend origin,
# e.g. https://mini-raft.vercel.app
ALLOWED_ORIGINS=

# Cloudflare Tunnel token (Zero Trust dashboard -> Networks -> Tunnels -> create -> copy token).
# Route the tunnel's public hostname to http://gateway:8080. See DEPLOY.md.
TUNNEL_TOKEN=

# Optional: committed entries between snapshots (replica/src/config.ts default is 500).
SNAPSHOT_THRESHOLD=500
